*.rar
bin-debug/
bin-release/

# WebGL
/[Ww]eb[Gg][Ll]/

# =============================================================================
# MISC / TOOLS
# =============================================================================
# JetBrains Rider cache
.idea/

# npm / node (if using any JS tooling)
node_modules/

# Autogenerated VS/Rider solution & project files
*.generated.sln
*.generated.csproj

# Unity smart merge backup files
*.orig.meta
*.orig

# Gradle (for Android builds)
.gradle/

# Burst AOT output
/[Aa]ssets/[Bb]urst[Aa]ot[Oo]utput*/

# TextMeshPro (keep settings, ignore generated resources)
/[Aa]ssets/[Tt]ext[Mm]esh[Pp]ro/Resources/Fonts & Materials/

# Streaming assets cache
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa/

# =============================================================================
# KEEP THESE (explicit overrides)
# =============================================================================
![Aa]ssets/
!ProjectSettings/
!Packages/
