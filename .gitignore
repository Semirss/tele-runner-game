# =============================================================================
# UNITY GENERATED FOLDERS
# =============================================================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Addressables — cache and build artifacts only (keep settings)
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*
![Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/DataBuilders/
![Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/Groups/
![Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/SchemaTemplates/
![Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/Settings.asset
![Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/Settings.asset.meta

# Bundles build output (keep source asset bundles in Assets/Bundles)
/[Bb]undle[Bb]uilds/

# =============================================================================
# UNITY CRASH / BACKTRACE FILES
# =============================================================================
sysinfo.txt
*.stackdump

